# Copy to .env and fill in values. See comments for what each vendor expects.

# --- Already used for LinkedIn Jobs / ThomasNet Apify actors ---
APIFY_TOKEN=

# --- LinkedIn Jobs (Apify actor valig/linkedin-jobs-scraper) ---
# No extra key beyond APIFY_TOKEN (pay-per-use on Apify).

# --- LinkedIn Profiles (optional Apify actor you choose) ---
APIFY_LINKEDIN_PROFILE_ACTOR=
APIFY_LINKEDIN_PROFILE_URLS=
# Or pass full JSON run input:
# APIFY_LINKEDIN_PROFILE_RUN_INPUT=

# --- ThomasNet.com (no official public API — this project uses an Apify scraper) ---
# Uses the same APIFY_TOKEN. You pay Apify actor usage, not ThomasNet.
APIFY_THOMASNET_ACTOR=zen-studio/thomasnet-suppliers-scraper
# Comma-separated product/company searches (defaults used if empty):
APIFY_THOMASNET_QUERIES=industrial HVAC equipment,industrial fans and blowers,mechanical engineering services
APIFY_THOMASNET_MAX_PER_QUERY=40
THOMASNET_SCRAPE_MODE=all

# --- Dodge Construction Network style data via ConstructConnect IO API ---
# You need a ConstructConnect subscription and the exact HTTPS URL they give you
# for project/lead search, plus an API key used as x-api-key.
CONSTRUCTCONNECT_API_KEY=
CONSTRUCTCONNECT_API_URL=
# Optional extra headers as JSON object:
# CONSTRUCTCONNECT_EXTRA_HEADERS_JSON=

# --- CIVcast ---
# Public REST documentation is not published in search results; your CIVcast
# account manager must supply a JSON API base URL and auth headers.
CIVCAST_API_URL=
# Example: {"Authorization":"Bearer ..."} or {"X-Api-Key":"..."}
CIVCAST_HTTP_HEADERS_JSON=
# Or drop a manual export from their UI:
# CIVCAST_LEADS_JSON=/path/to/civcast_export.json

# --- Industry database ---
# Either a CSV path with columns: company,website,post_url,source,signal_category,signal_evidence,person_name,job_title
INDUSTRY_LEADS_CSV=
# Or an HTTPS URL that returns JSON (array or {data:[...]}) with those fields:
INDUSTRY_LEADS_JSON_URL=

# --- Optional manual Dodge JSON (same row shape as CIVcast file) ---
# DODGE_LEADS_JSON=

# --- Pipeline tuning ---
TARGET_LEAD_COUNT=100
LINKEDIN_LEAD_TARGET=50
NON_LINKEDIN_LEAD_TARGET=50
MIN_ICP_SCORE=5
MIN_FACILITY_EXPANSION_COUNT=20
MIN_NEW_PRODUCT_DEVELOPMENT_COUNT=20
# Weighted average scoring (0..10 components)
ICP_WEIGHT_INDUSTRY_FIT=1.0
ICP_WEIGHT_SIGNAL_STRENGTH=2.0
ICP_WEIGHT_ROLE_RELEVANCE=1.0
ICP_WEIGHT_COMPANY_FIT=1.0
STRICT_FIFTY_FIFTY=false
# MILESTONE1_DEMO_MODE=1
